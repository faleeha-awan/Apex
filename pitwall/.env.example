# Copy this to .env and fill in your keys
# Never commit .env to GitHub

ANTHROPIC_API_KEY=your_anthropic_key_here
GITHUB_TOKEN=your_github_token_here   # optional — needed for private repos, higher rate limits

# ChromaDB stores data here
CHROMA_DB_PATH=./data/chroma_db

# SQLite for gap tracking
GAPS_DB_PATH=./data/gaps.db

# Retrieval settings
TOP_K_CHUNKS=8
CHUNK_SIZE=512
CHUNK_OVERLAP=64
